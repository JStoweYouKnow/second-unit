# Supabase Configuration (required for client build AND /api serverless routes on Vercel)
VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional but recommended for admin/server operations (invite validation works with anon key via RPC)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Local dev origin (OAuth/email confirm callbacks when running on localhost)
VITE_SITE_URL=http://localhost:5173

# Canonical production URL — invite links, password reset, and auth callbacks
# from Vercel preview deployments always redirect here (not the preview URL).
# Use www — apex (thecallsheet.ai) redirects to www on Vercel.
# Must match Supabase Auth → URL Configuration → Site URL + Redirect URLs.
VITE_PRODUCTION_URL=https://www.thecallsheet.ai

# API Server (local dev only — leave UNSET on Vercel so /api/* hits serverless functions)
VITE_API_URL=http://localhost:3001
API_PORT=3001
FRONTEND_URL=http://localhost:5173

# Stripe (server-side — REQUIRED for checkout; missing key fails closed with HTTP 503)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Never enable on Vercel production. Local demos only (does not mark bookings paid).
# ALLOW_MOCK_PAYMENTS=true

# Sentry (optional — error monitoring)
# Server / serverless:
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
# Client (Vite):
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Email (optional — Resend for transactional alerts)
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=The Callsheet <notifications@yourdomain.com>

# Web Push (optional — browser notifications via VAPID)
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:notifications@yourdomain.com

# Google Calendar OAuth (optional — two-way sync + busy import)
GOOGLE_CALENDAR_CLIENT_ID=your-google-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=your-google-client-secret
# Defaults to {FRONTEND_URL}/api/calendar/callback if unset
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/api/calendar/callback

# Local Stripe webhook forwarding:
#   stripe listen --forward-to localhost:3001/api/webhooks/stripe
# Test card: 4242 4242 4242 4242
